{
  "name": "medace-study-space-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run build && npm run test:api",
    "test:unit": "vitest run",
    "test:api": "node scripts/run-api-integration-tests.mjs",
    "test:smoke": "playwright test --config=playwright.smoke.config.ts",
    "test:ios-simulator": "node scripts/run-ios-simulator-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "cf:preview": "vite build && wrangler pages dev dist",
    "cf:doctor": "node scripts/cf-doctor.mjs",
    "cf:doctor:strict": "node scripts/cf-doctor.mjs --include-deferred",
    "cf:sync": "node scripts/cf-sync.mjs",
    "db:migrate:local": "wrangler d1 migrations apply medace-db --local",
    "db:migrate:verify": "bash -lc 'tmpdir=$(mktemp -d); cleanup() { rm -rf \"$tmpdir\"; }; trap cleanup EXIT; wrangler d1 migrations apply medace-db --local --persist-to \"$tmpdir\"'",
    "db:migrate:remote": "wrangler d1 migrations apply medace-db --remote",
    "db:seed:sql": "node scripts/build-seed-sql.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@playwright/test": "^1.54.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vitest": "^3.2.4",
    "vite": "^6.2.0",
    "wrangler": "^4.58.0"
  }
}
